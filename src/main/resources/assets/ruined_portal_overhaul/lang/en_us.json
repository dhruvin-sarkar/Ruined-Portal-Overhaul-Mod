  "rei.ruined_portal_overhaul.nether_conduit.title": "Nether Conduit Attunement",
  "rei.ruined_portal_overhaul.nether_conduit.line1": "Surround the conduit with 12 nether bricks to awaken it.",
  "rei.ruined_portal_overhaul.nether_conduit.line2": "Base pulse grants Fire Resistance, Haste, Regeneration, and an 8-block nether strike for 4 damage.",
  "rei.ruined_portal_overhaul.nether_conduit.line3": "Ancient debris upgrades cost 1 debris for level 1 and 2 debris for level 2.",
  "rei.ruined_portal_overhaul.nether_conduit.line4": "Full attunement expands the strike to 16 blocks, raises it to 8 damage, and nearly removes lava drag.",
  "rei.ruined_portal_overhaul.nether_crystal.title": "Nether Crystal Ritual",
  "rei.ruined_portal_overhaul.nether_crystal.line1": "Craft with 4 nether stars, 2 netherite ingots, 2 crying obsidian, and a Nether Conduit.",
  "rei.ruined_portal_overhaul.nether_crystal.line2": "After clearing a portal dungeon, place one crystal on each stored pedestal.",
  "rei.ruined_portal_overhaul.nether_crystal.line3": "Filling all four pedestals begins the Nether Dragon summoning ritual.",
  "rei.ruined_portal_overhaul.ghast_tear_necklace.title": "Ghast Tear Necklace",
  "rei.ruined_portal_overhaul.ghast_tear_necklace.line1": "Carry the necklace to keep Speed II and Jump Boost II refreshed every 40 ticks.",
  "rei.ruined_portal_overhaul.ghast_tear_necklace.line2": "The Nether Fireball uses the bound key and always spawns server-side.",
  "rei.ruined_portal_overhaul.ghast_tear_necklace.line3": "Each shot shares a 2 minute cooldown stored directly on the necklace.",
  "rei.ruined_portal_overhaul.ghast_tear_necklace.line4": "Recipe: 4 ghast tears, 2 nether stars, and 2 gold ingots.",
  "rei.ruined_portal_overhaul.nether_star.title": "Nether Star Sources",
